{
	"info": {
		"_postman_id": "b0c3732f-ef2e-4d6c-b12c-07842f5d0c5a",
		"name": "Print Beat Jobs",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "10916568"
	},
	"item": [
		{
			"name": "Get Jobs - Print Attempt",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"require('crypto-js');",
							"",
							"var key = pm.environment.get(\"key\");",
							"var secret = pm.environment.get(\"secret\");",
							"var endpoint = \"/externalApi/jobs\";",
							"var headers = createHeaders (\"GET\", endpoint );",
							"",
							"pm.environment.set(\"hmacHeader\", headers[0]);",
							"pm.environment.set(\"timestamp\", headers[1]);",
							"",
							"function createHeaders(method, path) {",
							"    var timestamp = (new Date()).toISOString();",
							"    ",
							"    var toSign = method.toUpperCase() + \" \" + path + timestamp;",
							"    console.log('Creating hash with string ', toSign);",
							"    var hash = CryptoJS.HmacSHA256(toSign, secret);",
							"    var sig = CryptoJS.enc.Hex.stringify(hash);",
							"    var headers = [",
							"      key + \":\" + sig,",
							"      timestamp",
							"    ];",
							"    return headers;",
							"}"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "x-hp-hmac-authentication",
						"value": "{{hmacHeader}}"
					},
					{
						"key": "x-hp-hmac-date",
						"value": "{{timestamp}}"
					},
					{
						"key": "x-hp-hmac-algorithm",
						"value": "SHA256",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{SmsHost}}/printbeat/externalApi/jobs?sortOrder=DESC",
					"host": [
						"{{SmsHost}}"
					],
					"path": [
						"printbeat",
						"externalApi",
						"jobs"
					],
					"query": [
						{
							"key": "devices",
							"value": "00000000",
							"disabled": true
						},
						{
							"key": "startMarker",
							"value": "{{marker}}",
							"disabled": true
						},
						{
							"key": "sortOrder",
							"value": "DESC"
						}
					]
				}
			},
			"response": []
		}
	]
}